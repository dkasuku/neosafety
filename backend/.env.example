# ---- Database ----
# Leave DATABASE_URL unset to use a local SQLite file (no install needed).
# To use PostgreSQL instead, uncomment and edit the line below:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neosafety

# ---- Flask ----
FLASK_SECRET=change-me-in-production

# ---- Admin panel login (http://localhost:5000/admin) ----
ADMIN_USER=admin
ADMIN_PASS=admin123

# ---- Frontend origin(s) allowed to call the API ----
CORS_ORIGINS=http://localhost:3000

# ---- WhatsApp number orders are sent to ----
WHATSAPP_NUMBER=254707866446


# Shared token the Next.js admin uses to call /api/admin (must match the frontend)
ADMIN_API_TOKEN=neo-admin-local-token
