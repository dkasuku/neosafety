# ---- NEO Safety storefront + admin (Next.js) ----
# Copy this file to .env.local and adjust as needed. All values have sensible
# defaults, so the admin panel works out of the box for local development.

# URL of the Flask backend API
NEXT_PUBLIC_API_URL=http://localhost:5000

# Public URL of the storefront (used for SEO/sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Password to sign in at /admin/login
ADMIN_PASSWORD=admin123

# Session cookie value set after a successful login (any random string)
ADMIN_SESSION_TOKEN=neo-admin-session-token

# Shared token the admin uses to call the backend admin API.
# MUST match ADMIN_API_TOKEN in the backend's environment.
ADMIN_API_TOKEN=neo-admin-local-token
